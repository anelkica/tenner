<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:controls="using:Tenner.Avalonia.Controls"
			 xmlns:gif="using:Avalonia.Labs.Gif"
			 x:Class="Tenner.Avalonia.Controls.GifCard">

	<Border Padding="6" Background="Transparent" ClipToBounds="False">
		<Border x:Name="Card" CornerRadius="8" ClipToBounds="True" Background="Red">
			<gif:GifImage x:Name="Gif" Source="avares://Tenner.Avalonia/Assets/Images/placeholder.gif" Stretch="Fill" IsHitTestVisible="False"/>
		</Border>
	</Border>
</UserControl>