<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:controls="using:Tenner.Avalonia.Controls"
			 xmlns:gif="using:Avalonia.Labs.Gif"
			 x:Class="Tenner.Avalonia.Controls.GifCard">

	<Border Padding="8" ClipToBounds="False">
		<Border x:Name="Card" CornerRadius="8" ClipToBounds="True" Background="Transparent">
			<gif:GifImage x:Name="Gif" Stretch="Fill" IsHitTestVisible="False"/>
		</Border>
	</Border>
</UserControl>